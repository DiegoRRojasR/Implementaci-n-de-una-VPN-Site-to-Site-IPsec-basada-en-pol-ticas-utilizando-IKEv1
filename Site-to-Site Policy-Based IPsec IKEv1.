Config IPsec IKEv1 en R1

conf t

! Trafico interesante (LAN-A <-> LAN-B)
ip access-list extended ACL-VPN
 permit ip 10.9.18.0 0.0.0.255 10.9.19.0 0.0.0.255

! IKEv1 - Phase 1
crypto isakmp policy 10
 encr aes 256
 hash sha
 authentication pre-share
 group 14
 lifetime 86400

crypto isakmp key C1sco-0918 address 172.16.9.5

! IPsec - Phase 2
crypto ipsec transform-set TS esp-aes 256 esp-sha-hmac
 mode tunnel

crypto map VPNMAP 10 ipsec-isakmp
 set peer 172.16.9.5
 set transform-set TS
 match address ACL-VPN

interface g0/0
 crypto map VPNMAP
end
wr mem

